  "diagnostic_tips": [
    { "id": 1, "category": "Thermal", "tip": "B182D16 (HV-PTC voltage too low) appears often when HV system fails to start but rarely indicates a real issue. Focus on why HV system is not starting." },
    { "id": 2, "category": "Gateway", "tip": "Gateway (0x4010, Part ID 9035) is the HV Coordinator. Check Gateway faults first. Full FC + DTC title reveals root cause. Over 60 DTCs for U112300 alone." },
    { "id": 3, "category": "Emergency Off", "tip": "Some HV faults trigger Emergency Off mode. Even after clearing all faults, Emergency Off may remain active. Reset via PIWIS: BMS > Drive Links > Resetting cell module deactivation." },
    { "id": 4, "category": "12V Battery", "tip": "Use approved Deutronic supply (VAS 5908) for jump-start. Do NOT leave jump box connected with HV deactivated. Mishandled jump-starts cause erroneous cell overvoltage/undervoltage faults." },
    { "id": 5, "category": "12V Battery", "tip": "If 12V battery can switch on ignition, it is likely not the underlying issue. Do not incorrectly associate HV errors with 12V battery." },
    { "id": 6, "category": "Fault Priority", "tip": "Not all stored faults indicate failure. Priority 1-4 = real faults. Priority 6 (Hinweis) = informational notices. Check freeze-frame for priority level." },
    { "id": 7, "category": "OBC", "tip": "Many OBC codes are informational notices stored in fully functional vehicles. See obc_benign_codes array for known benign codes." },
    { "id": 8, "category": "OTA", "tip": "ARB6 OTA software update has caused charging irregularities. Dealer may need code clearing, HV shutdown, 12V reset to restore normal charging." },
    { "id": 9, "category": "OBC", "tip": "Electrical system error > OBC failure > HV heater failure is a reported progression pattern. Monitor for escalation if OBC codes appear." },
    { "id": 10, "category": "General", "tip": "A single root cause (12V discharge, OTA failure, CAN bus issue) can produce faults across 10+ ECUs simultaneously. Identify root cause before chasing individual codes." }
  ]
}
