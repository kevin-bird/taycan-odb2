    "APB5": { "nhtsa": "23V840", "description": "HV battery module short circuit risk (initial)", "years": "2021-2024", "remedy": "Battery module replacement/monitoring software" },
    "ARA4": { "nhtsa": "24V215", "description": "HV battery module short circuit risk (supplement 1)", "years": "2021-2024", "remedy": "Data analytics + hardware analysis" },
    "ARA5": { "nhtsa": "24V217", "description": "HV battery module short circuit risk (supplement 2)", "years": "2021-2024", "remedy": "Data analytics + hardware analysis" },
    "ARB6": { "nhtsa": "24V732", "description": "HV battery short circuit - expanded recall, charge limit 80%", "years": "2020-2024", "remedy": "Advanced diagnostic software (Q1 2025). Interim: charge max 80%." },
    "ARB7": { "nhtsa": "24V732", "description": "HV battery - monitoring, no anomalies currently", "years": "2020-2024", "remedy": "Monitoring. No charge restriction." },
